// Copy to `Secrets.xcconfig` (ignored by git) and fill in values.
//
// Find these in Supabase Dashboard:
// Settings → API
// - Project URL
// - anon/public key

// NOTE: In `.xcconfig`, `//` starts a comment, so `https://...` would be parsed as `https:`.
// Use a host-only value and the app will build the full URL as `https://{host}`.
SUPABASE_HOST = YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY

// Branding / org config (safe to commit, overridden per org in Secrets.xcconfig).
// App display name shown on the login screen and under the app icon.
DHD_APP_DISPLAY_NAME = MultiOrg
// Public website host (no scheme). App will open `https://{host}`.
// Support contact email used on "Access required" screen.
DHD_SUPPORT_EMAIL = support@example.com
// Legacy username domain for the username→email bridge login.
DHD_LEGACY_EMAIL_DOMAIN = legacy.dhd.local

// Temporary: bypass access entitlement checks so everyone can use the app
// until Stripe / entitlements are configured.
// Set to 0 to re-enable the paywall.
DHD_BYPASS_ACCESS = 0

// DEV ONLY: show "Entitlement Test" buttons (coach-only) in Account → Subscription/Access.
// This does not touch Stripe or require any payment; it calls an internal Edge Function.
// Recommended: keep 0 unless you're actively testing.

// Stripe Payment Link (subscription).
// The app will open this URL in the browser and append:
// `client_reference_id=<supabase_user_uuid>` so the webhook can attribute the subscription.
// IMPORTANT: `.xcconfig` treats `https://` as a comment (because of `//`).
// Store without scheme; the app will prepend `https://` at runtime.
